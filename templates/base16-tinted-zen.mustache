/* {{scheme-name}} by {{scheme-author}} */
/* base16-tinted-zen — https://github.com/GooseRooster/base16-tinted-zen */

:root {
    /* --- Zen primary accent --- */
    --zen-primary-color:                  #{{base0D-hex}};

    /* --- Derived accent overrides (bypass Zen's color-mix derivations) --- */
    --zen-colors-primary:                 #{{base0D-hex}};
    --zen-colors-secondary:               #{{base02-hex}};
    --zen-colors-tertiary:                #{{base01-hex}};
    --zen-colors-hover-bg:                #{{base02-hex}};
    --zen-colors-primary-foreground:      #{{base05-hex}};
    --zen-colors-border:                  #{{base02-hex}};
    --zen-colors-border-contrast:         #{{base04-hex}};
    --zen-colors-input-bg:                #{{base01-hex}};

    /* --- Backgrounds --- */
    --zen-main-browser-background:        #{{base00-hex}};
    --zen-dialog-background:              #{{base01-hex}};
    --zen-branding-dark:                  #{{base00-hex}};
    --zen-branding-paper:                 #{{base07-hex}};

    /* --- Toolbar --- */
    --zen-toolbar-element-bg:             #{{base01-hex}};
    --zen-toolbar-element-bg-hover:       #{{base02-hex}};
    --zen-urlbar-background:              #{{base01-hex}};
    --zen-input-border-color:             rgb({{base02-rgb-r}}, {{base02-rgb-g}}, {{base02-rgb-b}});

    /* --- Sidebar --- */
    --zen-sidebar-notification-bg:        #{{base0D-hex}};
    --zen-sidebar-themed-icon-fill:       #{{base05-hex}};
    --zen-appcontent-border:              1px solid #{{base02-hex}};

    /* --- Firefox standard variables --- */
    --toolbar-bgcolor:                    #{{base01-hex}};
    --toolbar-color:                      #{{base05-hex}};
    --toolbarbutton-icon-fill:            #{{base05-hex}};
    --toolbarbutton-hover-background:     #{{base02-hex}};
    --toolbarbutton-active-background:    #{{base03-hex}};
    --urlbar-box-bgcolor:                 #{{base01-hex}};
    --urlbar-box-hover-bgcolor:           #{{base02-hex}};
    --urlbar-box-focus-bgcolor:           #{{base01-hex}};
    --urlbar-box-text-color:              #{{base05-hex}};
    --tab-selected-bgcolor:               #{{base02-hex}};
    --tab-selected-color:                 #{{base05-hex}};
    --arrowpanel-background:              #{{base01-hex}};
    --arrowpanel-color:                   #{{base05-hex}};
    --arrowpanel-border-color:            #{{base02-hex}};
}
